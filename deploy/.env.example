# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bastion
DB_USER=bastion
DB_PASSWORD=changeme

# Auth
JWT_SECRET=changeme-generate-a-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Server
BASTION_HOST=0.0.0.0
BASTION_PORT=8080
BASTION_DOMAIN=localhost

# Trusted reverse-proxy networks (comma-separated CIDRs). The server honors
# X-Forwarded-For / X-Real-IP (for rate limiting and logging) ONLY from these
# source ranges; from anywhere else it uses the real socket peer. Leave EMPTY if
# the server is exposed directly (never trust forwarding headers then).
#
# In this docker-compose stack the server sits behind Caddy on the pinned
# "bastion" network, so trust that subnet. A malformed value fails startup, and
# an all-sources range (0.0.0.0/0) is warned about — never use one.
BASTION_TRUSTED_PROXIES=172.28.0.0/16

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Uploads
BASTION_UPLOAD_DIR=/app/uploads
BASTION_UPLOAD_MAX_SIZE=10MB

# Email (optional — enables password reset emails)
# If not configured, password reset will be unavailable.
# Supports Mailgun HTTP API (preferred) or SMTP.
#
# Mailgun API (recommended — works even when SMTP ports are blocked):
#   BASTION_MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   BASTION_MAILGUN_DOMAIN=yourdomain.com
#   BASTION_MAILGUN_FROM=Bastion <noreply@yourdomain.com>
BASTION_MAILGUN_API_KEY=
BASTION_MAILGUN_DOMAIN=
BASTION_MAILGUN_FROM=
#
# SMTP (fallback if Mailgun is not configured):
#   BASTION_SMTP_HOST=smtp.mailgun.org
#   BASTION_SMTP_PORT=587
#   BASTION_SMTP_USER=bastion@yourdomain.com
#   BASTION_SMTP_PASS=your-smtp-password
#   BASTION_SMTP_FROM=Bastion <noreply@yourdomain.com>

# GIF Search (optional — enables GIF picker in chat)
# Configure ONE of the following. If both are set, Tenor takes priority.
# If neither is set, the GIF button is hidden and the feature is disabled.
#
# Tenor (Google Cloud API key with Tenor API enabled):
#   Free tier: 5,000 requests/day
#   Get one at https://developers.google.com/tenor/guides/quickstart
BASTION_TENOR_API_KEY=
#
# Giphy (alternative):
#   Free tier for non-commercial use
#   Get one at https://developers.giphy.com/dashboard/?create=true
BASTION_GIPHY_API_KEY=
