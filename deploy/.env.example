# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bastion
DB_USER=bastion
DB_PASSWORD=changeme

# Auth
JWT_SECRET=changeme-generate-a-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Server
BASTION_HOST=0.0.0.0
BASTION_PORT=8080
BASTION_DOMAIN=localhost

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Uploads
BASTION_UPLOAD_DIR=/app/uploads
BASTION_UPLOAD_MAX_SIZE=10MB

# SMTP (optional — enables password reset emails)
# If not configured, password reset will be unavailable
# Example using Mailgun:
#   BASTION_SMTP_HOST=smtp.mailgun.org
#   BASTION_SMTP_PORT=587
#   BASTION_SMTP_USER=bastion@yourdomain.com
#   BASTION_SMTP_PASS=your-smtp-password
#   BASTION_SMTP_FROM=Bastion <noreply@yourdomain.com>
BASTION_SMTP_HOST=
BASTION_SMTP_PORT=587
BASTION_SMTP_USER=
BASTION_SMTP_PASS=
BASTION_SMTP_FROM=
