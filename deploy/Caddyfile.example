# Replace YOUR_DOMAIN with your actual domain.
#
# Caddy sets X-Forwarded-For automatically. The Go server only trusts it from
# the networks in BASTION_TRUSTED_PROXIES (the pinned "bastion" subnet in
# docker-compose), so real client IPs drive rate limiting instead of collapsing
# onto Caddy's address.
YOUR_DOMAIN {
	# API and WebSocket — proxy to Go backend
	handle /api/* {
		reverse_proxy server:8080
	}

	# Everything else — serve the web client
	handle {
		reverse_proxy web:80
	}
}
